# ─── AI Provider ─────────────────────────────────────────────────────────────
KANIT_AI_MODE=nvidia          # nvidia | ollama | mock
KANIT_ALLOW_MOCK=false        # true = fallback to mock if AI fails (dev only)
KANIT_API_KEY=                # API key for KANIT endpoint (optional, leave empty for dev)
KANIT_MAX_UPLOAD_BYTES=5242880

# ─── NVIDIA NIM ───────────────────────────────────────────────────────────────
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TEXT_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_VISION_MODEL=nvidia/llama-nemotron-nano-vl-8b
NVIDIA_OCR_MODEL=nvidia/nemo-asr-ocr-v2
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
NVIDIA_TIMEOUT_SECONDS=60
NVIDIA_MAX_TOKENS=1024

# ─── Database ─────────────────────────────────────────────────────────────────
# Option A: Supabase (production — persistent, multi-tenant)
KANIT_STORE=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Option B: SQLite (local dev only — data lost on Vercel cold start)
# KANIT_STORE=sqlite
# KANIT_DB_PATH=kanit.sqlite3

# ─── Multi-tenant (optional for single-org setup) ────────────────────────────
KANIT_ORG_ID=                 # Set to lock backend to one organization

# ─── CORS (production: set to your frontend domain) ──────────────────────────
KANIT_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ─── Webhooks ─────────────────────────────────────────────────────────────────
KANIT_WEBHOOK_URL=            # n8n or custom webhook for audit events

# ─── Local AI (Ollama) ────────────────────────────────────────────────────────
# KANIT_AI_MODE=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TEXT_MODEL=llama3.3
OLLAMA_VISION_MODEL=llava
OLLAMA_TIMEOUT_SECONDS=60
